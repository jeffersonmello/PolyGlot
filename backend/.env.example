# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# File storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_FILE_SIZE=52428800

# Logging
LOG_LEVEL=info

# Translation APIs (at least one required for real translations)
# If none are set, the mock provider is used automatically.
DEEPL_API_KEY=
OPENAI_API_KEY=

# DeepL API endpoint (use https://api.deepl.com/v2 for paid plans)
DEEPL_API_URL=https://api-free.deepl.com/v2
